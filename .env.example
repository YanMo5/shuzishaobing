# PostgreSQL Configuration
POSTGRES_DB=campus_health
POSTGRES_USER=campus_health
POSTGRES_PASSWORD=your_secure_password_here

# Spring Boot Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/campus_health
SPRING_DATASOURCE_USERNAME=campus_health
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
CAMPUS_PLATFORM_OUTBOX_DISPATCH_INTERVAL_MS=1000
SERVER_PORT=8080

# Frontend
VITE_API_BASE_URL=http://localhost:8080
NODE_ENV=production
